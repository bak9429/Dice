%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 94b8c5eed92cceb40a26b6f422c11574, type: 3}
  m_Name: INV_SabertoothMutant
  m_EditorClassIdentifier: 
  bossId: midboss_sabertooth_mutant
  displayName: Sabertooth Mutant
  themeId: forest
  places:
  - placeId: place_forest_edge
    displayName: 숲 가장자리
    shortDescription: 숲의 바깥과 안쪽이 만나는 경계. 젖은 흙과 밤안개 때문에 첫 흔적이 잘 남는다.
    themeTag: forest
  - placeId: place_moon_path
    displayName: 월광 산책로
    shortDescription: 나무 사이가 열리며 달빛이 직접 쏟아지는 길목. 움직임의 방향과 속도가 잘 드러난다.
    themeTag: forest
  - placeId: place_hunter_hut
    displayName: 사냥꾼의 오두막
    shortDescription: 오래전에 버려진 목조 오두막. 사람의 흔적과 피 냄새가 섞여 있어 습성을 읽기 좋다.
    themeTag: forest
  - placeId: place_dark_clearing
    displayName: 어둠의 공터
    shortDescription: 숲이 갑자기 끊기며 열리는 작은 공터. 사냥의 마무리 흔적이 모이기 쉬운 장소다.
    themeTag: forest
  - placeId: place_old_shrine
    displayName: 오래된 제단
    shortDescription: 숲속에 반쯤 묻힌 낡은 석조 제단. 전승과 거짓 단서가 섞이기 쉬운 장소다.
    themeTag: forest
  spawnablePlaceIds:
  - place_forest_edge
  - place_moon_path
  - place_hunter_hut
  - place_dark_clearing
  - place_old_shrine
  investigationNodes:
  - nodeId: sb_node_01
    nodeRole: 0
    variantsBySpawnPlace:
    - spawnPlaceId: place_forest_edge
      displayName: 숲 가장자리
      locationId: place_forest_edge
      reviewSummaryText: 숲 가장자리에서는 몸을 낮추었다가 폭발적으로 튀어나간 듯한 흔적이 반복적으로 발견되었다.
      steps:
      - stepType: 0
        textStep:
          text: >
            숲의 경계는 생각보다 조용했다. 비가 막 그친 듯 흙은 물기를 머금고 있었고, 발목 높이의 안개가 천천히 흘렀다.
            발자국의 간격은 몇 걸음은 느슨하게 이어지다가 어느 지점에서 갑자기 짧아지고, 그 자리의 흙은 넓고 깊게 눌려 있었다.
            같은 패턴이 두 번, 세 번 반복된다. 걷다가 멈춘 것이 아니라, 몸을 바짝 낮추었다가 짧은 거리에서 폭발적으로 튀어나간 움직임처럼 보인다.
        choiceStep:
          promptText: 
          choices: []
        resultStep:
          text: 
          grantedHint: {hintId: '', text: '', quality: 0, category: 0, relatedAnswerId: ''}
          advantageValue: 0
          nextStepIndex: -1
      - stepType: 1
        textStep: {text: ''}
        choiceStep:
          promptText: 무엇을 먼저 조사할까?
          choices:
          - choiceId: trace_stride
            text: 발자국의 간격과 눌린 자국을 비교한다
            nextStepIndex: -1
            resultText: 자국의 간격을 따라가 보니 놈은 몸을 완전히 접어 힘을 모은 뒤 폭발적으로 앞으로 튀어나간다.
            grantedHint:
              hintId: sb_hint_01
              text: 놈은 도약 직전에 몸을 낮추는 습성이 있다.
              quality: 0
              category: 1
              relatedAnswerId: trait_pounce
            advantageValue: 2
          - choiceId: trace_brush
            text: 찢긴 수풀과 털 자국을 살핀다
            nextStepIndex: -1
            resultText: 수풀에는 밝은 털과 검은 털이 섞여 있다. 놈이 어둠과 그림자를 능숙하게 이용한다는 느낌이 든다.
            grantedHint:
              hintId: sb_hint_02
              text: 놈은 밤과 그림자 속에서 존재감을 흐린다.
              quality: 1
              category: 2
              relatedAnswerId: symbol_nightbeast
            advantageValue: 0
          - choiceId: trace_bone
            text: 부서진 뼈와 낙서를 조사한다
            nextStepIndex: -1
            resultText: 바위 표면에는 '불을 두려워한다'는 번진 글씨가 남아 있지만 단서로 쓰기엔 불안정하다.
            grantedHint:
              hintId: sb_hint_03
              text: 불을 두려워했다는 기록이 남아 있다.
              quality: 2
              category: 0
              relatedAnswerId: weak_fire
            advantageValue: 0
        resultStep:
          text: 
          grantedHint: {hintId: '', text: '', quality: 0, category: 0, relatedAnswerId: ''}
          advantageValue: 0
          nextStepIndex: -1
  - nodeId: sb_node_02
    nodeRole: 1
    variantsBySpawnPlace: []
  - nodeId: sb_node_03
    nodeRole: 2
    variantsBySpawnPlace: []
  - nodeId: sb_node_04
    nodeRole: 3
    variantsBySpawnPlace: []
  finalDeductionNode:
    reviewVariantsBySpawnPlace:
    - spawnPlaceId: place_forest_edge
      reviewSteps:
      - text: 첫 흔적은 놈이 몸을 낮춘 뒤 단번에 거리를 좁히는 포식자라는 점을 드러냈다.
      - text: 불에 대한 낙서도 있었지만, 실제 반복된 단서는 도약 자세와 충돌 직전의 힘 모으기였다.
    questionText: 지금까지 수집한 단서를 종합해 Sabertooth Mutant의 약점과 현재 잠복하고 있을 장소를 추리하라.
    weaknessOptions:
    - answerId: weak_fire
      text: 화염에 취약하다
    - answerId: weak_shock
      text: 충격에 취약하다
    - answerId: weak_light
      text: 빛에 취약하다
    placeOptions:
    - answerId: place_forest_edge
      text: 숲 가장자리
    - answerId: place_moon_path
      text: 월광 산책로
    - answerId: place_hunter_hut
      text: 사냥꾼의 오두막
    - answerId: place_dark_clearing
      text: 어둠의 공터
    - answerId: place_old_shrine
      text: 오래된 제단
    correctWeaknessId: weak_shock
    correctPlaceMap:
    - spawnPlaceId: place_forest_edge
      correctPlaceId: place_forest_edge
    - spawnPlaceId: place_moon_path
      correctPlaceId: place_moon_path
    - spawnPlaceId: place_hunter_hut
      correctPlaceId: place_hunter_hut
    - spawnPlaceId: place_dark_clearing
      correctPlaceId: place_dark_clearing
    - spawnPlaceId: place_old_shrine
      correctPlaceId: place_old_shrine
  skipRule:
    allowSkip: 1
    statMask: 6
    baseChance: 5
    perStatBonus: 2
    maxChance: 45
    maxInvestigationAdvantageBonus: 10
  successDebuffIds:
  - boss_first_turn_delay_small
  - boss_stagger_down_small
